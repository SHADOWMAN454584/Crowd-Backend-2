# ─── CrowdSense AI Backend — Environment Variables ────────────────────────────
# Copy this to .env and fill in your real keys.

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=CrowdSense AI Backend
VERSION=1.0.0
DEBUG=false

# CORS: comma-separated origins, or * for all
ALLOWED_ORIGINS=["*"]

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Google Maps ────────────────────────────────────────────────────────────────
# Requires: Places API + Directions API + Maps JavaScript API enabled
# Get from https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=AIza...

# ── Admin ──────────────────────────────────────────────────────────────────────
# Used to protect POST /realtime/train
ADMIN_SECRET=crowdsense-admin-2024
